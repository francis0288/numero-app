generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String
  logoUrl         String?
  brandingFooter  String?
  phone           String?
  brandingEmail   String?
  defaultLanguage String   @default("en")
  createdAt       DateTime @default(now())
  clients         Client[]
}

model Client {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  firstName         String
  middleName        String?
  lastName          String
  birthCertName     String
  currentName       String
  dateOfBirth       DateTime
  email             String?
  phone             String?
  preferredLanguage String    @default("vi")
  shareToken        String    @unique @default(cuid())
  notes             String?
  destinyMethod     String?   @default("A")
  soulMethod        String?   @default("A")
  personalityMethod String?   @default("A")
  createdAt         DateTime  @default(now())
  readings          Reading[]
}

model Reading {
  id              String    @id @default(cuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  version         Int
  language        String    @default("en")
  profileJSON     String
  aiNarrative     String?
  editedNarrative String?
  tone            String    @default("warm")
  status          String    @default("draft")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sessions        Session[]
}

model Session {
  id        String   @id @default(cuid())
  readingId String
  reading   Reading  @relation(fields: [readingId], references: [id])
  type      String
  question  String?
  answer    String?
  createdAt DateTime @default(now())
}

model Interpretation {
  id         String   @id @default(cuid())
  numberKey  String
  locale     String
  category   String
  baseText   String
  editedText String?
  updatedAt  DateTime @updatedAt

  @@unique([numberKey, locale])
}

model MbInterpretation {
  id         Int      @id @default(autoincrement())
  numberKey  String   @map("number_key")
  category   String
  catVi      String?  @map("cat_vi")
  keywordsEn String?  @map("keywords_en")
  textEn     String   @map("text_en")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([numberKey, category])
  @@map("interpretations")
}
